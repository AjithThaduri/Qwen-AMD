# ── Config: Q5 quantized GGUF, 8K context window ─────────────────────────────
# Q5_K_M (~25–27 GB for 35B) offers slightly better quality than Q4_K_M (~21–23 GB).
# The MI300X has 192 GiB VRAM so both fit with massive headroom.

MODEL_TYPE="gguf"
SERVED_MODEL_NAME="${SERVED_MODEL_NAME_Q5:-qwen3.6-35b-a3b-q5}"
MAX_MODEL_LEN="8192"
DTYPE="float16"
