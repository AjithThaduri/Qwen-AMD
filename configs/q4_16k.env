# ── Config: Q4 quantized GGUF, 16K context window ────────────────────────────
# Run this only after q4_8k passes with acceptable latency.
# Larger context means a larger KV cache and higher VRAM usage at load time.

MODEL_TYPE="gguf"
SERVED_MODEL_NAME="${SERVED_MODEL_NAME_Q4:-qwen3.6-35b-a3b-q4}"
MAX_MODEL_LEN="16384"
DTYPE="float16"
