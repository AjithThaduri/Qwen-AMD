# ── Config: FP8 HuggingFace model, 8K context window ─────────────────────────
# FP8 fallback — used if GGUF Q4/Q5 proves unstable or too slow on ROCm vLLM.
# It loads directly from HF — no local GGUF file needed.
# Requires HF_TOKEN if the model is gated.

MODEL_TYPE="fp8_hf"
SERVED_MODEL_NAME="${SERVED_MODEL_NAME_FP8:-qwen3.6-35b-a3b-fp8}"
MAX_MODEL_LEN="8192"
DTYPE="auto"
# "auto" lets vLLM detect FP8 natively; do not force float16 for FP8 models.
