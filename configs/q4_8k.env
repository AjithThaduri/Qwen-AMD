# ── Config: Q4 quantized GGUF, 8K context window ─────────────────────────────
# Use this for the first test run. Lowest memory footprint, fastest to load.
# Source this file before running the serve script, or let 06_serve_q4_8k.sh
# load it automatically.

MODEL_TYPE="gguf"
SERVED_MODEL_NAME="${SERVED_MODEL_NAME_Q4:-qwen3.6-35b-a3b-q4}"
MAX_MODEL_LEN="8192"
DTYPE="float16"
# Note: float16 is used for GGUF models on ROCm; bfloat16 is preferred for
# native HF models but GGUF loaders in vLLM require float16.
