# ══════════════════════════════════════════════════════════════════════════════
# .env.example — copy to .env and fill in your real values
# NEVER commit .env to git.
# ══════════════════════════════════════════════════════════════════════════════

# ── RunPod connection ─────────────────────────────────────────────────────────
# Full SSH command — "SSH over exposed TCP" in RunPod → your pod → Connect
RUNPOD_SSH_COMMAND="ssh root@213.173.96.55 -p 14871 -i ~/.ssh/runpod_ed25519"

# RunPod proxy SSH (alternative — no direct IP needed, but no SCP/SFTP):
# ssh mv4dfc2mn9l8zc-644116fc@ssh.runpod.io -i ~/.ssh/id_ed25519

# Your RunPod pod ID
RUNPOD_POD_ID="mv4dfc2mn9l8zc"

# Public URL for port 8000 (RunPod forms this automatically)
RUNPOD_PUBLIC_BASE_URL="https://mv4dfc2mn9l8zc-8000.proxy.runpod.net"

# ── API security ──────────────────────────────────────────────────────────────
# vLLM requires this key on every request. Change for any real deployment.
VLLM_API_KEY="dev-test-key"

# ── Hugging Face ──────────────────────────────────────────────────────────────
# Required to download models from HF.
# Create a read-only token at: https://huggingface.co/settings/tokens
HF_TOKEN=""

# ── Model storage on the RunPod pod ──────────────────────────────────────────
# /workspace persists across pod restarts on RunPod (unlike /tmp).
MODEL_DIR="/workspace/models"

# ── GGUF model file paths (on the pod, set after 05_download_models.sh) ──────
# Source: bartowski/Qwen_Qwen3.6-35B-A3B-GGUF
# Q4_K_M is ~21–23 GB; Q5_K_M is ~25–27 GB (estimated for 35B model)
# IMPORTANT: Verify exact filename at:
#   https://huggingface.co/bartowski/Qwen_Qwen3.6-35B-A3B-GGUF/tree/main
Q4_MODEL_PATH="/workspace/models/Qwen_Qwen3.6-35B-A3B-Q4_K_M.gguf"
Q5_MODEL_PATH="/workspace/models/Qwen_Qwen3.6-35B-A3B-Q5_K_M.gguf"

# ── Hugging Face model IDs ────────────────────────────────────────────────────
# FP8 — used only if GGUF proves unstable or too slow on ROCm (fallback).
# Check if this exists: https://huggingface.co/Qwen/Qwen3.6-35B-A3B-FP8
FP8_MODEL_ID="Qwen/Qwen3.6-35B-A3B-FP8"

# Tokenizer: vLLM requires the HF tokenizer even when loading a GGUF file.
TOKENIZER_ID="Qwen/Qwen3.6-35B-A3B"

# ── Model names shown in the /v1/models API response ─────────────────────────
SERVED_MODEL_NAME_Q4="qwen3.6-35b-a3b-q4"
SERVED_MODEL_NAME_Q5="qwen3.6-35b-a3b-q5"
SERVED_MODEL_NAME_FP8="qwen3.6-35b-a3b-fp8"

# ── vLLM server settings ─────────────────────────────────────────────────────
VLLM_HOST="0.0.0.0"
VLLM_PORT="8000"

# Context window. Start with 8192 (safe first run); extend to 16384 after baseline.
MAX_MODEL_LEN="8192"

# Fraction of VRAM for KV cache. 0.88 = 88%, leaving ~23 GiB headroom on MI300X.
GPU_MEMORY_UTILIZATION="0.88"

# ── GGUF download source ──────────────────────────────────────────────────────
# bartowski uses imatrix calibration — most compatible with vLLM's GGUF loader.
# No official Qwen GGUF repo exists for Qwen3.6-35B-A3B.
# IMPORTANT: Before running 05_download_models.sh, verify exact filenames at:
#   https://huggingface.co/bartowski/Qwen_Qwen3.6-35B-A3B-GGUF/tree/main
GGUF_HF_REPO="bartowski/Qwen_Qwen3.6-35B-A3B-GGUF"
GGUF_Q4_FILENAME="Qwen_Qwen3.6-35B-A3B-Q4_K_M.gguf"
GGUF_Q5_FILENAME="Qwen_Qwen3.6-35B-A3B-Q5_K_M.gguf"
